<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ backup / device-transfer rules.
    See https://developer.android.com/about/versions/12/backup-restore#xml-changes

    Excluded artifacts:
      * auth.db          — bearer-token-bound profile cache.
      * scan.db          — practitioner PII (license + verified-license records).
      * auth_prefs.xml   — EncryptedSharedPreferences. The MasterKey lives in the
                           hardware-backed keystore and does NOT travel with backups,
                           so the bytes would be unrecoverable on another device, but
                           we exclude them anyway to avoid shipping ciphertext blobs.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="auth.db" />
        <exclude domain="database" path="scan.db" />
        <exclude domain="sharedpref" path="auth_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="auth.db" />
        <exclude domain="database" path="scan.db" />
        <exclude domain="sharedpref" path="auth_prefs.xml" />
    </device-transfer>
</data-extraction-rules>

<?xml version="1.0" encoding="utf-8"?>
<!--
    Legacy Auto Backup rules used by Android 11 (API 30) and below.
    See https://developer.android.com/guide/topics/data/autobackup
    On Android 12+ the rules in res/xml/data_extraction_rules.xml take precedence.

    Excluded artifacts mirror data_extraction_rules.xml — see that file for rationale.
-->
<full-backup-content>
    <exclude domain="database" path="auth.db" />
    <exclude domain="database" path="scan.db" />
    <exclude domain="sharedpref" path="auth_prefs.xml" />
    <exclude domain="sharedpref" path="db_keys.xml" />
    <exclude domain="sharedpref" path="db_migration_guard.xml" />
</full-backup-content>

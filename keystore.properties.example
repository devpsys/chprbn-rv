# Copy to `keystore.properties` and fill in real values. The file is
# gitignored — never commit it.
#
# Generate a release keystore (one-time, keep the .jks safe + backed up):
#   keytool -genkey -v -keystore chprbn-release.jks -alias chprbn -keyalg RSA -keysize 2048 -validity 10000
#
# `storeFile` is resolved relative to the project root.
storeFile=chprbn-release.jks
storePassword=CHANGE_ME
keyAlias=chprbn
keyPassword=CHANGE_ME
